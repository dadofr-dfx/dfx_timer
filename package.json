{
  "name": "dfx-timer",
  "version": "1.0.0",
  "main": "main.js",
  "description": "DFX Timer Overlay",
  "author": "DFX",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^11.5.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.dfx.timer",
    "productName": "DFX Timer",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "DFX Timer",
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "uninstallDisplayName": "Desinstalar DFX Timer"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!.github/*"
    ]
  }
}
